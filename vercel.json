{
  "version": 2,
  "buildCommand": "sh scripts/vercel-build.sh",
  "outputDirectory": "dist/pdf-excel-ai-frontend/browser",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "methods": [
        "POST",
        "PUT",
        "PATCH",
        "DELETE",
        "OPTIONS",
        "GET",
        "HEAD"
      ],
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "methods": [
        "GET",
        "HEAD"
      ],
      "dest": "/index.html"
    }
  ]
}
